# PalmPay Integration Environment Variables
# Copy this file to .env and fill in your actual PalmPay API credentials

# PalmPay API Configuration
PALMPAY_MERCHANT_ID=your_palmpay_merchant_id_here
PALMPAY_API_KEY=your_palmpay_api_key_here
PALMPAY_SECRET_KEY=your_palmpay_secret_key_here

# Optional: Set to 'production' for live transactions, 'sandbox' for testing
PALMPAY_ENVIRONMENT=sandbox

# Note: These credentials should be obtained from your PalmPay merchant dashboard
# Never commit actual credentials to version control